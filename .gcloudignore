# .gcloudignore (SAFE DEFAULT)
.gcloudignore
.git
.git/**
.github
.github/**
__pycache__
__pycache__/**
*.pyc
*.pyo
*.pyd
.env
.env.*
.vscode
.idea
.DS_Store

# IMPORTANT: explicitly KEEP these
!app.yaml
!main.py
!requirements.txt
!index.html
!favicon.ico

# KEEP app code + static dirs (directory + contents)
!api/
!api/**
!statics/
!statics/**
